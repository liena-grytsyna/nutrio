POSTGRES_DB=nutrio
POSTGRES_USER=nutrio
POSTGRES_PASSWORD=change_me_to_a_strong_password

PGADMIN_DEFAULT_EMAIL=admin@nutrio.app
PGADMIN_DEFAULT_PASSWORD=change_me_to_a_strong_pgadmin_password

# Docker Compose sets DATABASE_URL for the API container automatically.
# Use this only if you run Prisma commands outside Docker and expose PostgreSQL locally.
# DATABASE_URL=postgresql://nutrio:change_me_to_a_strong_password@localhost:5432/nutrio?schema=public
