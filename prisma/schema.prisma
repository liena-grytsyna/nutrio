generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  servingSize String   @default("100 g") @map("serving_size")
  calories    Float
  protein     Float
  fat         Float
  carbs       Float
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("products")
}

model DayEntry {
  id        String   @id @default(cuid())
  name      String
  amount    Float
  calories  Float
  protein   Float
  fat       Float
  carbs     Float
  deviceId  String   @map("device_id")
  eatenAt   DateTime @map("eaten_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([eatenAt])
  @@index([deviceId, eatenAt])
  @@map("day_entries")
}
