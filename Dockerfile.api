FROM node:22-alpine

RUN apk add --no-cache openssl

WORKDIR /app

COPY package*.json ./
ENV PRISMA_SKIP_POSTINSTALL_GENERATE=true
RUN npm ci

COPY prisma ./prisma
COPY prisma.config.ts ./

ENV DATABASE_URL="postgresql://nutrio:nutrio@db:5432/nutrio?schema=public"
RUN npm run prisma:generate

COPY server ./server

EXPOSE 3000

CMD ["sh", "-c", "npm run prisma:migrate:deploy && npm run api:start"]
